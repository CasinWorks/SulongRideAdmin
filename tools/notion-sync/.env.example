# Copy to .env and fill in your values (never commit .env)
NOTION_API_KEY=secret_your_integration_secret

# Parent page URL or page ID where the tracker database should live
NOTION_PARENT_PAGE_ID=https://www.notion.so/your-workspace/your-parent-page-id

# Optional: set after first run to target an existing database (skips create)
# NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required for Features databases that use Notion's Project relation column.
# Open the SulongRide project in Notion, copy the page ID from the URL, and share
# that project page with your integration (Connections).
# NOTION_PROJECT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: map multiple project labels to page IDs
# NOTION_PROJECT_PAGE_IDS=SulongRide:abc123...,Other Project:def456...
